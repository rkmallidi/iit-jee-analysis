# Database
POSTGRES_USER=jee_admin
POSTGRES_PASSWORD=jee_secret
POSTGRES_DB=iit_jee_analysis
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://jee_admin:jee_secret@localhost:5432/iit_jee_analysis

# Auth
JWT_SECRET_KEY=change-me-to-a-long-random-string-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=1

# App
APP_ENV=development
APP_NAME=IIT JEE Analysis
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Bootstrap admin (seed)
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_ADMIN_PASSWORD=Admin@12345
BOOTSTRAP_ADMIN_FULL_NAME=System Administrator
